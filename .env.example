# EduClearance environment template
# Copy to .env.local for local development.
# In production, set these names in Vercel Project Settings > Environment Variables.

# Database
DATABASE_URL="postgresql://postgres:password@localhost:54321/edu_clearance"

# App URL + support contact
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SUPPORT_EMAIL="hey@jstarstudios.com"

# Paystack
# Local/dev can use test keys. Vercel Production should use live keys.
PAYSTACK_SECRET_KEY="sk_test_replace_me"
PAYSTACK_PUBLIC_KEY="pk_test_replace_me"
PAYSTACK_WEBHOOK_SECRET="whsec_replace_me"

# Vercel build behavior
# Keep false locally. Set true in Vercel Production only if you want deploy-time migrations.
RUN_DB_MIGRATIONS="false"

# One-off admin bootstrap only; do not commit real values.
PLATFORM_ADMIN_NAME="Your Name"
PLATFORM_ADMIN_EMAIL="admin@example.com"
PLATFORM_ADMIN_PASSWORD="REPLACE_WITH_LONG_RANDOM_PASSWORD"
PLATFORM_ADMIN_PHONE=""

# One-off destructive production reset only; never set by default.
ALLOW_DESTRUCTIVE_PRODUCTION_RESET="false"
RESET_DATABASE_CONFIRM=""
